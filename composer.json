{
    "name": "gosa/galaxy",
    "description": "Galaxie Open Source Application - Plateforme de gestion de domaines métier open source",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^12",
        "friendsofphp/php-cs-fixer": "^3",
        "phpstan/phpstan": "^2"
    },
    "autoload": {
        "psr-4": {
            "Gosa\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Gosa\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
