{
    "name": "gosa/galaxy",
    "description": "Galaxie Open Source Application - Plateforme de gestion de domaines métier open source",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.5",
        "symfony/console": "^7.2",
        "symfony/dotenv": "^7.2",
        "symfony/framework-bundle": "^7.2",
        "symfony/runtime": "^7.2",
        "symfony/yaml": "^7.2 || ^8.0"
    },
    "require-dev": {
        "behat/behat": "^3.31",
        "friends-of-behat/symfony-extension": "^2.6",
        "friendsofphp/php-cs-fixer": "^3",
        "phpstan/phpstan": "^2",
        "phpunit/phpunit": "^12"
    },
    "autoload": {
        "psr-4": {
            "Gosa\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Gosa\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "symfony/runtime": true
        }
    },
    "extra": {
        "runtime": {
            "env_var_name": "APP_ENV"
        }
    }
}
